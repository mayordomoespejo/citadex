# Angular uses environment.ts (not .env files) for build-time configuration.
# Fill in these values in src/environments/environment.ts before running the app.

# Firebase — create a new project at https://console.firebase.google.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Supabase — same dev-hub instance as Pulse
# Find this at https://app.supabase.com → Project Settings → API → Project URL
SUPABASE_URL=
